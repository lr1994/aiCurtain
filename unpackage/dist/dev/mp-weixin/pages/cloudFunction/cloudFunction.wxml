<view class="curtain-page"><view class="hero-shell"><view class="hero-card"><view class="hero-topbar"><view class="hero-brand">{{a}}</view><view class="hero-avatar" bindtap="{{c}}"><text class="hero-avatar-icon">{{b}}</text></view></view><view class="hero-greeting">{{d}}</view><view class="hero-points">{{e}}</view><view class="hero-hint">{{f}}</view></view></view><view class="workbench-card"><view class="upload-deck"><view class="upload-card" bindtap="{{m}}"><view class="upload-title">上传空窗照</view><image wx:if="{{g}}" src="{{h}}" mode="aspectFill" class="upload-preview"/><view wx:else class="upload-illustration upload-illustration--window"><view class="illustration-frame"><view class="illustration-hill"></view><view class="illustration-sun"></view></view></view><view class="upload-trigger"><text class="upload-trigger-icon">+</text></view><view class="upload-footer"><text class="upload-link" catchtap="{{j}}">{{i}}</text><text wx:if="{{k}}" class="upload-link upload-link--danger" catchtap="{{l}}">清空</text></view></view><view class="upload-arrow"><text>&gt;</text></view><view class="upload-card" bindtap="{{t}}"><view class="upload-title">上传面料/成品图</view><image wx:if="{{n}}" src="{{o}}" mode="aspectFill" class="upload-preview"/><view wx:else class="upload-illustration upload-illustration--fabric"><view class="fabric-roll"><view class="fabric-core"></view></view></view><view class="upload-trigger"><text class="upload-trigger-icon">+</text></view><view class="upload-footer"><text class="upload-link" catchtap="{{q}}">{{p}}</text><text wx:if="{{r}}" class="upload-link upload-link--danger" catchtap="{{s}}">清空</text></view></view></view><view class="section-title">风格设置</view><picker range="{{w}}" range-key="label" value="{{x}}" bindchange="{{y}}"><view class="setting-row"><text class="setting-label">褶皱倍数：</text><view class="setting-value"><text>{{v}}</text><text class="setting-arrow">▼</text></view></view></picker><picker range="{{A}}" range-key="label" value="{{B}}" bindchange="{{C}}"><view class="setting-row"><text class="setting-label">帘头款式：</text><view class="setting-value"><text>{{z}}</text><text class="setting-arrow">▼</text></view></view></picker><view class="switch-row" bindtap="{{F}}"><text class="setting-label">包含纱帘？</text><view class="{{['checkbox-box', E]}}"><text wx:if="{{D}}">x</text></view></view><view class="prompt-panel"><view class="prompt-head"><text class="prompt-title">高级提示词</text><text class="prompt-count">{{G}}/300</text></view><block wx:if="{{r0}}"><textarea class="prompt-input" maxlength="300" placeholder="描述你希望的窗帘融合效果" placeholder-class="prompt-placeholder" value="{{H}}" bindinput="{{I}}"/></block></view><button class="submit-btn" loading="{{K}}" disabled="{{L}}" bindtap="{{M}}">{{J}}</button><view class="recharge-line"><text class="recharge-text">点数不足？</text><text class="recharge-link" bindtap="{{N}}">去充值</text></view></view><view wx:if="{{O}}" class="result-card"><view class="section-head"><text class="section-head-title">生成结果</text><text class="section-head-link" bindtap="{{P}}">预览大图</text></view><image src="{{Q}}" mode="widthFix" class="result-image" bindtap="{{R}}"/></view><view class="history-card"><view class="section-head"><text class="section-head-title">最近记录</text><text class="section-head-link" bindtap="{{S}}">刷新</text></view><view wx:if="{{T}}" class="history-empty"><text class="history-empty-title">登录后可查看你的私有历史记录</text><text class="history-empty-desc">当前方案按用户隔离存储，不再共享公开历史。</text></view><view wx:elif="{{U}}" class="history-empty"><text class="history-empty-title">历史记录加载中...</text></view><view wx:elif="{{V}}" class="history-empty"><text class="history-empty-title">还没有生成记录</text><text class="history-empty-desc">上传两张图并生成后，这里会展示最近 10 条结果。</text></view><view wx:else class="history-list"><view wx:for="{{W}}" wx:for-item="item" wx:key="h" class="history-item" bindtap="{{item.i}}"><image src="{{item.a}}" mode="aspectFill" class="history-thumb"/><view class="history-body"><view class="history-top"><text class="{{['history-status', item.c]}}">{{item.b}}</text><text class="history-time">{{item.d}}</text></view><text class="history-prompt">{{item.e}}</text><view class="history-links"><text class="history-link" catchtap="{{item.f}}">预览</text><text class="history-link" catchtap="{{item.g}}">回显</text></view></view></view></view></view></view>