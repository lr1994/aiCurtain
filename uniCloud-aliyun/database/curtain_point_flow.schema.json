{
  "bsonType": "object",
  "required": [
    "uid",
    "type",
    "amount",
    "balanceAfter",
    "bizType",
    "status",
    "createTime",
    "updateTime"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "流水ID，系统自动生成"
    },
    "uid": {
      "description": "用户ID",
      "bsonType": "string"
    },
    "type": {
      "description": "流水类型",
      "bsonType": "string"
    },
    "amount": {
      "description": "变动点数",
      "bsonType": "int"
    },
    "balanceAfter": {
      "description": "变动后余额",
      "bsonType": "int"
    },
    "bizType": {
      "description": "业务类型",
      "bsonType": "string"
    },
    "bizId": {
      "description": "业务关联ID",
      "bsonType": "string"
    },
    "remark": {
      "description": "备注",
      "bsonType": "string"
    },
    "status": {
      "description": "记录状态",
      "bsonType": "bool"
    },
    "createTime": {
      "description": "创建时间",
      "bsonType": "timestamp",
      "defaultValue": {
        "$env": "now"
      }
    },
    "updateTime": {
      "description": "更新时间",
      "bsonType": "timestamp",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
