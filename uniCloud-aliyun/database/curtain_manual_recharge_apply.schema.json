{
  "bsonType": "object",
  "required": [
    "uid",
    "contact",
    "remark",
    "status",
    "createTime",
    "updateTime"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "申请ID，系统自动生成"
    },
    "uid": {
      "description": "用户ID",
      "bsonType": "string"
    },
    "contact": {
      "description": "联系方式",
      "bsonType": "string"
    },
    "remark": {
      "description": "申请备注",
      "bsonType": "string"
    },
    "status": {
      "description": "申请状态",
      "bsonType": "string"
    },
    "createTime": {
      "description": "创建时间",
      "bsonType": "timestamp",
      "defaultValue": {
        "$env": "now"
      }
    },
    "updateTime": {
      "description": "更新时间",
      "bsonType": "timestamp",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
