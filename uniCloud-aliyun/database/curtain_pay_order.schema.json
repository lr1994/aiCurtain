{
  "bsonType": "object",
  "required": [
    "uid",
    "packageId",
    "packageTitle",
    "orderNo",
    "amountFen",
    "points",
    "status",
    "payType",
    "createTime",
    "updateTime"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "订单ID，系统自动生成"
    },
    "uid": {
      "description": "用户ID",
      "bsonType": "string"
    },
    "packageId": {
      "description": "套餐ID",
      "bsonType": "string"
    },
    "packageTitle": {
      "description": "套餐名称",
      "bsonType": "string"
    },
    "orderNo": {
      "description": "订单编号",
      "bsonType": "string"
    },
    "amountFen": {
      "description": "订单金额，单位分",
      "bsonType": "int"
    },
    "points": {
      "description": "到账点数",
      "bsonType": "int"
    },
    "payType": {
      "description": "支付方式",
      "bsonType": "string"
    },
    "status": {
      "description": "订单状态",
      "bsonType": "string"
    },
    "transactionId": {
      "description": "支付流水号",
      "bsonType": "string"
    },
    "payTime": {
      "description": "支付时间",
      "bsonType": "timestamp"
    },
    "createTime": {
      "description": "创建时间",
      "bsonType": "timestamp",
      "defaultValue": {
        "$env": "now"
      }
    },
    "updateTime": {
      "description": "更新时间",
      "bsonType": "timestamp",
      "forceDefaultValue": {
        "$env": "now"
      }
    }
  }
}
